# IT Helpdesk Agent - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# PRIVATE LLM CONFIGURATION
# =============================================================================
LLM_ENDPOINT=http://your-llm-endpoint/v1/chat/completions
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-model-name
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_MS=30000

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
API_PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=your-secure-jwt-secret-min-32-chars
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# EMAIL CONFIGURATION (Future - Currently Disabled)
# =============================================================================
# SMTP_HOST=smtp.your-server.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=it-helpdesk@your-company.com
# ESCALATION_EMAIL=it-support@your-company.com

# =============================================================================
# LOGGING & AUDIT CONFIGURATION
# =============================================================================
LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=365
PII_REDACTION_ENABLED=true

# =============================================================================
# FEATURE FLAGS (MVP)
# =============================================================================
FEATURE_PRIVILEGED_ACTIONS=false
FEATURE_APPROVAL_WORKFLOWS=false
FEATURE_EMAIL_ESCALATION=false

# =============================================================================
# AZURE AD / MICROSOFT 365 CONFIGURATION (Phase 2)
# =============================================================================
# Get these from Azure Portal → App Registrations → Your App
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Microsoft Graph API endpoint (usually don't change this)
GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0

# =============================================================================
# AZURE AD TEST USERS (For Safe Testing Only)
# =============================================================================
# Create dedicated test users in Azure AD before testing
# These should have "test" in the email for safety checks
AZURE_TEST_USER_EMAIL=testuser1@yourdomain.onmicrosoft.com
AZURE_TEST_USER_2_EMAIL=testuser2@yourdomain.onmicrosoft.com

# =============================================================================
# JISR HR SYSTEM (Phase 2 - Future)
# =============================================================================
# JISR_API_BASE_URL=https://api.jisr.net/v1
# JISR_API_KEY=your-jisr-api-key
# JISR_WEBHOOK_SECRET=your-webhook-secret
